# Supabase — from your project's Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER exposed to the client, never prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Google AdSense — leave blank until AdSense approval (Milestone 6)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Canonical site URL (no trailing slash), e.g. https://deuce.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
