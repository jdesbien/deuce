# Supabase — from your project's Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER exposed to the client, never prefixed NEXT_PUBLIC_.
# Required for billing (Stripe webhook writes subscription state).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe billing (Pro ad-free tier) — test-mode keys until launch.
# Server-only:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Client-safe:
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=

# Google AdSense — blank until AdSense approval
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=

# Canonical site URL (no trailing slash), e.g. https://cards4couples.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
